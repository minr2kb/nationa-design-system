{
  "name": "@nation-a/icons",
  "version": "0.4.2",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf src/components",
    "gen:icons": "tsx src/scripts/generate-icons.ts",
    "gen:icons-svgr": "tsx src/scripts/generate-icons-svgr.ts",
    "gen:index": "tsx src/scripts/create-index.ts",
    "prebuild": "pnpm clean && pnpm gen:icons && pnpm gen:index",
    "build": "tsup"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-prettier": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3",
    "@types/react-dom": "^18.3",
    "eslint": "^8.40.0",
    "tsup": "^6.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./v3": {
      "types": "./dist/v3/index.d.ts",
      "require": "./dist/v3/index.cjs",
      "import": "./dist/v3/index.mjs"
    }
  }
}
